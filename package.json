{
  "name": "commiq-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "dev": "pnpm -r dev",
    "example": "pnpm --filter @naikidev/commiq-example dev",
    "docs": "pnpm --filter @naikidev/docs start",
    "build:core": "pnpm --filter @naikidev/commiq build",
    "build:react": "pnpm --filter @naikidev/commiq-react build",
    "build:libs": "pnpm --filter @naikidev/commiq build && pnpm --filter @naikidev/commiq-react build",
    "test:core": "pnpm --filter @naikidev/commiq test",
    "test:react": "pnpm --filter @naikidev/commiq-react test",
    "aspire": "docker compose up -d",
    "aspire:stop": "docker compose down",
    "version:bump": "node scripts/bump.mjs",
    "release": "pnpm -r publish --access public --no-git-checks"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "protobufjs",
      "sharp"
    ],
    "ignoredBuiltDependencies": [
      "core-js",
      "core-js-pure"
    ],
    "overrides": {
      "@types/node": "^24"
    }
  }
}
