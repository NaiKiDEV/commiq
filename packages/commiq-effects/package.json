{
  "name": "@naikidev/commiq-effects",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/NaiKiDEV/commiq"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "@naikidev/commiq": "workspace:*"
  },
  "devDependencies": {
    "@naikidev/commiq": "workspace:*",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^3.0.0"
  }
}
